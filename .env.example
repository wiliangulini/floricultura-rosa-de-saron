# ============================================================
# BANCO DE DADOS
# ============================================================

# String de conexão PostgreSQL (obrigatória)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ============================================================
# SITE
# ============================================================

# URL pública do site em produção (obrigatória em produção)
# Usada em: canonical, Open Graph, sitemap, JSON-LD
# Exemplo: https://floricultura-rosa-de-saron.com.br
NEXT_PUBLIC_SITE_URL="https://seudominio.com.br"

# ============================================================
# AUTENTICAÇÃO DO PAINEL ADMIN
# ============================================================

# Segredo HMAC para assinar os tokens de sessão (obrigatória)
# Deve ser uma string aleatória com no mínimo 32 caracteres
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-uma-string-longa-e-aleatoria-com-pelo-menos-32-caracteres"

# ============================================================
# IMAGENS — CLOUDINARY (opcional no MVP)
# ============================================================
# O upload de imagens está previsto para uma fase posterior ao MVP.
# Estas variáveis só são necessárias quando o upload for ativado.

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Pasta onde as imagens de produto serão armazenadas no Cloudinary
CLOUDINARY_FOLDER="produtos"
